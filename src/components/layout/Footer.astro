---
import { menuLinks, siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="w-full py-6 text-gray-600 dark:text-gray-400">
	<div class="mx-auto flex w-full max-w-4xl flex-col items-center gap-y-2 px-4 text-center align-top font-semibold sm:flex-row sm:justify-between sm:px-6 sm:text-xs">
		<div class="me-0 sm:me-4">
			&copy; {siteConfig.author}
			{year}.<span class="inline-block">&nbsp;{siteConfig.title}</span>
		</div>
		<nav
			aria-labelledby="footer_links"
			class="flex gap-x-2 sm:gap-x-0 sm:divide-x sm:divide-gray-500"
		>
			<p id="footer_links" class="sr-only">More on this site</p>
			{
				menuLinks.map((link) => (
					<a class="hover:text-global-text px-4 py-2 hover:underline sm:py-0" href={link.path}>
						{link.title}
					</a>
				))
			}
		</nav>
	</div>
</footer>
